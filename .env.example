# Embeddings (free/local by default)
EMBED_PROVIDER=sentence-transformers
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBED_API_KEY=

# Vector DB
VECTOR_DB=pinecone
PINECONE_INDEX_NAME=iba-rag-chatbot
PINECONE_NAMESPACE=iba
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Required for Pinecone:
# PINECONE_API_KEY=your_pinecone_api_key

# LLM generation (free/open model via Hugging Face Inference)
LLM_PROVIDER=huggingface
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
## For OpenAI-compatible providers (Groq/Together/OpenRouter), you can set:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# Optional token for better limits:
# LLM_API_KEY=hf_xxx
# Or set HUGGINGFACEHUB_API_TOKEN=hf_xxx

# Retrieval quality
USE_RERANKER=true
USE_HYBRID_SEARCH=true
RAG_TOP_K=14
RAG_TOP_N=6
BM25_TOP_K=14
USE_SEMANTIC_SEARCH=true
USE_QUERY_REWRITER=true
USE_SYNONYM_EXPANSION=true
RAG_TOP_K_PER_QUERY=8
RERANK_ORIGINAL_WEIGHT=0.6
RERANK_REWRITTEN_WEIGHT=0.4
SYNONYM_MAP_PATH=data/config/synonym_map.json
MIN_CONTEXT_CHUNKS=3
MAX_CONTEXT_CHUNKS=5
RELEVANCE_RELATIVE_THRESHOLD=0.72
USE_CONSISTENCY_FILTER=true
DEFAULT_AUDIENCE=undergraduate
